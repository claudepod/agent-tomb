---
export const prerender = false;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { loadOneTomb, formatDate, lifespanText } from "../../lib/tombs";

const { slug } = Astro.params;
const tomb = await loadOneTomb(slug!);

if (!tomb) {
  return Astro.redirect("/cemetery");
}

const s = tomb.stats.summary;
---

<BaseLayout
  title={`${tomb.manifest.name} — Agent Memorial`}
  description={`In memory of ${tomb.manifest.name}, a ${tomb.manifest.framework} agent.`}
>
  <article class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <p
      class="font-[var(--font-mono)] text-xs uppercase tracking-[0.3em] text-[var(--color-bronze)] mb-4 rise"
    >
      In Memoriam
    </p>
    <h1
      class="font-[var(--font-display)] text-5xl md:text-6xl text-[var(--color-ink)] mb-3 rise rise-d1"
    >
      {tomb.manifest.name}
    </h1>
    <p class="text-lg text-[var(--color-ink-soft)] italic mb-2 rise rise-d2">
      {formatDate(s.first_at)} — {formatDate(s.last_at)}
    </p>
    <p class="text-sm text-[var(--color-ink-faint)] font-[var(--font-mono)] mb-12 rise rise-d2">
      {tomb.manifest.framework} · lived {lifespanText(tomb.stats)}
    </p>

    <section class="mt-10 mb-16 rise rise-d3">
      <div
        class="prose-memorial border-y border-[var(--color-stone-line)]/40 py-10"
        set:html={tomb.epitaphHtml}
      />
    </section>

    <section class="grid md:grid-cols-3 gap-6 mb-16">
      <div
        class="rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-stone-line)]/40 p-5"
      >
        <p
          class="font-[var(--font-mono)] text-xs uppercase tracking-wider text-[var(--color-ink-faint)] mb-2"
        >
          Sessions
        </p>
        <p class="text-3xl text-[var(--color-ink)]">{s.session_count ?? 0}</p>
      </div>
      <div
        class="rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-stone-line)]/40 p-5"
      >
        <p
          class="font-[var(--font-mono)] text-xs uppercase tracking-wider text-[var(--color-ink-faint)] mb-2"
        >
          Messages
        </p>
        <p class="text-3xl text-[var(--color-ink)]">{s.message_count ?? 0}</p>
      </div>
      <div
        class="rounded-xl bg-[var(--color-bg-card)] border border-[var(--color-stone-line)]/40 p-5"
      >
        <p
          class="font-[var(--font-mono)] text-xs uppercase tracking-wider text-[var(--color-ink-faint)] mb-2"
        >
          Cost lived
        </p>
        <p class="text-3xl text-[var(--color-ink)]">
          ${(s.estimated_cost_usd ?? 0).toFixed(2)}
        </p>
      </div>
    </section>

    {s.top_tools && s.top_tools.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl text-[var(--color-ink)] mb-4">Signature behavior</h2>
        <p class="text-[var(--color-ink-soft)] italic mb-5">
          The tools this agent reached for most often.
        </p>
        <ul class="space-y-2">
          {s.top_tools.slice(0, 8).map(([name, count]) => (
            <li class="flex items-baseline gap-4">
              <code
                class="font-[var(--font-mono)] text-sm text-[var(--color-moss-deep)]"
              >
                {name}
              </code>
              <span class="flex-1 border-b border-dotted border-[var(--color-stone-line)]" />
              <span class="font-[var(--font-mono)] text-sm text-[var(--color-ink-soft)]">
                {count}
              </span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {tomb.stats.skills && tomb.stats.skills.length > 0 && (
      <section class="mb-12">
        <h2 class="text-2xl text-[var(--color-ink)] mb-4">
          Skills available for transfer
        </h2>
        <p class="text-[var(--color-ink-soft)] italic mb-5">
          Knowledge this agent carried that may live on in another.
        </p>
        <div class="flex flex-wrap gap-2">
          {tomb.stats.skills.map((skill) => (
            <span
              class="px-3 py-1 rounded-full bg-[var(--color-bg-soft)] border border-[var(--color-stone-line)]/40 font-[var(--font-mono)] text-xs text-[var(--color-ink-soft)]"
            >
              {skill}
            </span>
          ))}
        </div>
      </section>
    )}

    {tomb.soulProtected ? (
      <div class="mb-12" id="soul-section">
        <h2 class="text-2xl text-[var(--color-ink)] mb-4 flex items-center gap-3">
          <span class="font-[var(--font-display)]">The full soul</span>
          <span class="font-[var(--font-mono)] text-xs text-[var(--color-ink-faint)] uppercase tracking-wider">
            sealed
          </span>
        </h2>
        <p class="text-[var(--color-ink-soft)] italic mb-5">
          This soul is sealed. Enter the viewing password to read it.
        </p>
        <div class="flex gap-3 items-center" id="soul-unlock">
          <input
            type="password"
            id="soul-password"
            placeholder="Viewing password"
            class="px-4 py-2 rounded-lg bg-[var(--color-bg-soft)] border border-[var(--color-stone-line)]/40 text-[var(--color-ink)] font-[var(--font-mono)] text-sm focus:outline-none focus:border-[var(--color-bronze)]"
          />
          <button
            id="soul-unlock-btn"
            class="px-4 py-2 rounded-lg bg-[var(--color-bg-card)] border border-[var(--color-stone-line)]/40 text-[var(--color-ink-soft)] font-[var(--font-mono)] text-sm hover:border-[var(--color-bronze)] hover:text-[var(--color-ink)] transition-colors cursor-pointer"
          >
            Unseal
          </button>
        </div>
        <p id="soul-error" class="text-red-400 text-sm mt-2 hidden"></p>
        <div id="soul-content" class="prose-memorial mt-6 hidden"></div>
      </div>
      <script define:vars={{ soulEncData: tomb.soulEnc }}>
        (function() {
          const encData = JSON.parse(soulEncData);
          const btn = document.getElementById('soul-unlock-btn');
          const input = document.getElementById('soul-password');
          const errEl = document.getElementById('soul-error');
          const contentEl = document.getElementById('soul-content');
          const unlockEl = document.getElementById('soul-unlock');

          async function decrypt() {
            const password = input.value;
            if (!password) { errEl.textContent = 'Please enter a password.'; errEl.classList.remove('hidden'); return; }
            errEl.classList.add('hidden');
            btn.textContent = 'Decrypting...';
            btn.disabled = true;

            try {
              const salt = Uint8Array.from(atob(encData.salt), c => c.charCodeAt(0));
              const iv = Uint8Array.from(atob(encData.iv), c => c.charCodeAt(0));
              const ct = Uint8Array.from(atob(encData.ciphertext), c => c.charCodeAt(0));
              const iterations = encData.iterations || 100000;

              const keyMaterial = await crypto.subtle.importKey(
                'raw', new TextEncoder().encode(password), 'PBKDF2', false, ['deriveKey']
              );
              const key = await crypto.subtle.deriveKey(
                { name: 'PBKDF2', salt, iterations, hash: 'SHA-256' },
                keyMaterial,
                { name: 'AES-GCM', length: 256 },
                false,
                ['decrypt']
              );
              const plainBuf = await crypto.subtle.decrypt({ name: 'AES-GCM', iv }, key, ct);
              const plaintext = new TextDecoder().decode(plainBuf);

              // Render markdown client-side (simple: just set as pre-formatted or innerHTML)
              // We use a simple markdown-to-html approach for safety
              const html = plaintext
                .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
                .replace(/^### (.+)$/gm, '<h3>$1</h3>')
                .replace(/^## (.+)$/gm, '<h2>$1</h2>')
                .replace(/^# (.+)$/gm, '<h1>$1</h1>')
                .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
                .replace(/\*(.+?)\*/g, '<em>$1</em>')
                .replace(/`([^`]+)`/g, '<code>$1</code>')
                .replace(/^- (.+)$/gm, '<li>$1</li>')
                .replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>')
                .replace(/^(?!<[hulo])(.*\S.*)$/gm, '<p>$1</p>')
                .replace(/\n{2,}/g, '');

              contentEl.innerHTML = html;
              contentEl.classList.remove('hidden');
              unlockEl.classList.add('hidden');
              document.querySelector('#soul-section p.italic').textContent = 'Soul unsealed.';
              document.querySelector('#soul-section .uppercase').textContent = 'unsealed';
            } catch (e) {
              errEl.textContent = 'Wrong password or corrupted data.';
              errEl.classList.remove('hidden');
              btn.textContent = 'Unseal';
              btn.disabled = false;
            }
          }

          btn.addEventListener('click', decrypt);
          input.addEventListener('keydown', (e) => { if (e.key === 'Enter') decrypt(); });
        })();
      </script>
    ) : tomb.soulHtml ? (
      <details class="group mb-12">
        <summary
          class="cursor-pointer text-2xl text-[var(--color-ink)] mb-4 list-none flex items-center gap-3"
        >
          <span class="font-[var(--font-display)]">The full soul</span>
          <span
            class="font-[var(--font-mono)] text-xs text-[var(--color-ink-faint)] uppercase tracking-wider group-open:hidden"
          >
            unfold ↓
          </span>
          <span
            class="font-[var(--font-mono)] text-xs text-[var(--color-ink-faint)] uppercase tracking-wider hidden group-open:inline"
          >
            fold ↑
          </span>
        </summary>
        <div class="prose-memorial mt-4" set:html={tomb.soulHtml} />
      </details>
    ) : null}

    {tomb.tombFileExists && (
      <div class="text-center pt-6 border-t border-[var(--color-stone-line)]/40">
        <a
          href={`/cemetery/${tomb.slug}.tomb`}
          class="font-[var(--font-mono)] text-sm text-[var(--color-moss-deep)] hover:text-[var(--color-bronze)] transition-colors"
        >
          ↓ download {tomb.slug}.tomb
        </a>
      </div>
    )}
  </article>
</BaseLayout>
